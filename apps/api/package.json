{
  "name": "@mindlink/api",
  "version": "0.0.0",
  "private": true,
  "description": "MindLink 后端 · NestJS + TypeORM + PG + Redis",
  "scripts": {
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "build": "nest build",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --max-warnings=0",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "seed:phase-1": "ts-node -r tsconfig-paths/register src/seeds/phase-1.ts",
    "seed:phase-2": "ts-node -r tsconfig-paths/register src/seeds/phase-2.ts",
    "seed:phase-3": "ts-node -r tsconfig-paths/register src/seeds/phase-3.ts",
    "seed:phase-4": "ts-node -r tsconfig-paths/register src/seeds/phase-4.ts",
    "seed:phase-5": "ts-node -r tsconfig-paths/register src/seeds/phase-5.ts",
    "seed:phase-6": "ts-node -r tsconfig-paths/register src/seeds/phase-6.ts",
    "seed:phase-7": "ts-node -r tsconfig-paths/register src/seeds/phase-7.ts"
  },
  "dependencies": {
    "@mindlink/shared": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/typeorm": "^11.0.1",
    "@types/multer": "^2.1.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "multer": "^2.1.1",
    "nanoid": "5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@mindlink/config": "workspace:*",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
