# ============================================================
# MindLink · 根级共用环境变量
# 复制本文件为 .env 后修改。各 app 可在自身目录再建 .env 覆盖
# ============================================================

# --- Common ---
NODE_ENV=development

# --- Database (Postgres) ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=mindlink
DB_PASSWORD=mindlink_dev
DB_DATABASE=mindlink

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Object Storage (MinIO for dev) ---
OSS_ENDPOINT=http://localhost:9000
OSS_REGION=us-east-1
OSS_BUCKET=mindlink
OSS_ACCESS_KEY=minioadmin
OSS_SECRET_KEY=minioadmin

# --- API ---
API_PORT=3000
API_BASE_URL=http://localhost:3000
JWT_SECRET=change-me-in-production-please
JWT_EXPIRES_IN=3600s
JWT_REFRESH_EXPIRES_IN=30d

# --- Admin Web (vite) ---
VITE_API_BASE=http://localhost:3000/api/v1

# --- LLM (phase 4+) ---
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=

# --- WeChat (phase 7+) ---
WECHAT_APP_ID=wx-placeholder
WECHAT_APP_SECRET=

# --- E-Sign (phase 3/8) ---
ESIGN_PROVIDER=mock
ESIGN_APP_ID=
ESIGN_APP_SECRET=

# --- SMS (phase 8) ---
SMS_PROVIDER=mock
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
