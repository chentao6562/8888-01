# MindLink · 生产环境变量示例
# 部署前根据本文件创建实际的 .env.production，并把所有 <change-me> 替换为真值。
# 严禁把真实值 commit 到仓库。

# ===== 必填 · bootstrap 缺失会立即抛错退出 =====

NODE_ENV=production
API_PORT=3000

# JWT · 至少 32 字符（推荐 `openssl rand -hex 32`）
JWT_SECRET=<change-me-at-least-32-chars>
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# AES-256-GCM 列加密 key · 32 字节 base64（推荐 `openssl rand -base64 32`）
ENCRYPTION_KEY=<change-me-base64-32-bytes>

# CORS 白名单（逗号分隔；空 / 缺失 → 启动失败）
CORS_ALLOWED_ORIGINS=https://app.mindlink.example.com,https://mp.mindlink.example.com

# 数据库（不能用默认 mindlink_dev）
DB_DRIVER=postgres
DB_HOST=postgres-rw.mindlink.svc
DB_PORT=5432
DB_DATABASE=mindlink
DB_USERNAME=mindlink
DB_PASSWORD=<change-me-strong>

# Redis
REDIS_HOST=redis.mindlink.svc
REDIS_PORT=6379
REDIS_PASSWORD=<change-me>

# ===== 真实 provider · 切换 mock → real 时必填 =====

# 微信小程序
WECHAT_PROVIDER=real
WECHAT_APP_ID=<change-me>
WECHAT_APP_SECRET=<change-me>

# 电子签（法大大）
ESIGN_PROVIDER=fadada
FADADA_APP_ID=<change-me>
FADADA_APP_SECRET=<change-me>
FADADA_BASE_URL=https://api.fadada.com
# 回调签名密钥（HMAC-SHA256），与 fadada 后台配置一致
ESIGN_CALLBACK_SECRET=<change-me-32-chars>

# LLM
LLM_PROVIDER=openai-compat
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_API_KEY=<change-me>

# 对象存储
COS_REGION=ap-shanghai
COS_BUCKET=mindlink-prod-1300000000
COS_SECRET_ID=<change-me>
COS_SECRET_KEY=<change-me>

# 短信
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=<change-me>
SMS_ACCESS_SECRET=<change-me>

# Sentry（可选但强烈建议）
SENTRY_DSN=<change-me>

# ===== 可选 =====

# 强制启用 Swagger UI 在生产（默认关闭）
# SWAGGER_ENABLED=1

# 注：生产严禁开启
# ALLOW_DEV_LOGIN — 已删除该 escape hatch · devLogin 在 NODE_ENV=production 下永远 403
